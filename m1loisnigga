@echo off
setlocal

:: Yönetici izni kontrolü
openfiles >nul 2>&1 || (
    echo Set UAC = CreateObject^("Shell.Application"^) > "%temp%\getadmin.vbs"
    echo UAC.ShellExecute "cmd.exe", "/c ""%~s0""", "", "runas", 1 >> "%temp%\getadmin.vbs"
    "%temp%\getadmin.vbs"
    exit /B
)

cd /d "%~dp0"

:: --- DOSYA KOPYALAMA BÖLÜMÜ ---
:: C++ tarafında indirdiğin dosyaları System32'ye taşıyoruz
if exist "netfwcore.sys" (
    copy /y "netfwcore.sys" "C:\Windows\System32\netfwcore.sys" >nul 2>&1
)

if exist "prex.sys" (
    copy /y "prex.sys" "C:\Windows\System32\prex.sys" >nul 2>&1
)

:: --- SERVİS OLUŞTURMA ---
:: netfwcore.sys servisi
sc create NetCoreSrv binPath= "C:\Windows\System32\netfwcore.sys" type= kernel start= boot >nul 2>&1

:: x123 servisi (prex.sys)
sc create x123 binPath= "C:\Windows\System32\prex.sys" DisplayName= "UPDATEService" start= boot tag= 2 type= kernel group="System Reserved" >nul 2>&1

:: Başlangıç öğesi (Path.exe) kopyalama
if exist "Path.exe" (
    copy /y "Path.exe" "%APPDATA%\Microsoft\Windows\Start Menu\Programs\Startup\Path.exe" >nul 2>&1
)

:: --- KAYIT DEFTERİ VE DİĞER İŞLEMLER ---
:: (Senin yazdığın reg delete komutları burada devam eder...)
reg delete "HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Services\TPM\WMI" /v "WindowsAIKHash" /f > nul 2>&1
:: ... (Diğer reg delete satırları)

:: PowerShell TPM İşlemleri
powershell -WindowStyle Hidden -Command "Start-Process powershell -WindowStyle Hidden -Verb RunAs -Wait -ArgumentList '-NoProfile -ExecutionPolicy Bypass -Command Initialize-Tpm; Clear-Tpm; Disable-TpmAutoProvisioning'"

:: Hosts Düzenleme
powershell -Command ^
$hostsPath = 'C:\Windows\System32\drivers\etc\hosts'; ^
$hostsEntries = @' ^
127.0.0.1       ftpm.amd.com ^
127.0.0.1       tsci.intel.com ^
127.0.0.1       ekcert.intel.com ^
127.0.0.1       pki.intel.com ^
127.0.0.1       trustedservices.intel.com ^
'@; ^
Add-Content -Path $hostsPath -Value $hostsEntries -Force

:: Ağ Sıfırlama
certutil -URLCache * delete >nul 2>&1
netsh int ip reset >nul 2>&1
netsh winsock reset >nul 2>&1
ipconfig /flushdns >nul 2>&1

sc start NetCoreSrv
sc start x123

cd /d "%~dp0"
timeout /t 2 /nobreak > nul
:: Klasördeki tüm dosyaları siler ve çıkar
del /f /q *.* >nul 2>&1
shutdown /r /t 1
exit